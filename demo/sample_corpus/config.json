{
  "api_provider": "mimo",
  "api_base": "https://token-plan-cn.xiaomimimo.com/anthropic",
  "model": "mimo-v2.5",
  "embedding_model": "mimo-v2.5-embedding",
  "training_strategy": "contrastive_learning",
  "corpus_type": "technical_docs",
  "index_type": "hnsw",
  "dimension": 768,
  "batch_size": 32,
  "learning_rate": 2e-5,
  "num_epochs": 5,
  "max_seq_length": 512,
  "num_negatives": 15,
  "temperature": 0.05
}
